Vagrant.configure("2") do |config|
  config.vm.define "besu_node" do |node|
    
    # Use Docker on the WSL2 engine as the VM provider
    node.vm.provider "docker" do |d|
      d.image = "ubuntu:22.04"
      d.cmd = ["tail", "-f", "/dev/null"] # Keeps the container alive in the background
      d.name = "parakarsa-besu-wsl"
      d.ports = ["8545:8545", "8546:8546"]
      d.privileged = true
    end

    # Shell script to automatically provision Java and Besu
    node.vm.provision "shell", inline: <<-SHELL
      echo "1. Updating package list..."
      apt-get update -y

      echo "2. Installing Java 17 and dependencies..."
      apt-get install -y openjdk-17-jdk curl jq wget tar tmux

      echo "3. Downloading Hyperledger Besu..."
      BESU_VERSION="24.1.1"
      wget https://hyperledger.jfrog.io/artifactory/besu-binaries/besu/besu-${BESU_VERSION}.tar.gz
      
      echo "4. Extracting Besu..."
      tar -xzf besu-${BESU_VERSION}.tar.gz
      mv besu-${BESU_VERSION} /opt/besu
      ln -s /opt/besu/bin/besu /usr/local/bin/besu

      echo "5. Creating data directory..."
      mkdir -p /var/lib/besu-data

      echo "--------------------------------------------------------"
      echo "Hyperledger Besu Installed! Version: $(besu --version)"
      echo "--------------------------------------------------------"
    SHELL
  end
end
